# Copy to .env.local and fill in. Get the project id by running:
#   npx sanity login   &&   npx sanity init --env
NEXT_PUBLIC_SANITY_PROJECT_ID=placeholder
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# HubSpot: Settings → Account Setup → Account Defaults shows your Hub/Portal ID.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
